{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format --check:*)",
      "Bash(mypy:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker ps:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(uv add:*)",
      "Bash(alembic upgrade:*)",
      "Bash(alembic downgrade:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)"
    ]
  }
}

# Copy to .env and fill in. NEVER commit .env (see .gitignore + gitleaks in CI).

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tradeforge
POSTGRES_USER=tradeforge
POSTGRES_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MetaTrader 5 terminal (Windows hosts only: collector + executor) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# --- Execution safeguards (see sdd.md §11) ---
KILL_SWITCH_ENABLED=true
MAX_DAILY_LOSS_PERCENT=3.0
MAX_OPEN_POSITIONS=1
